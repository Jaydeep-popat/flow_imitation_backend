
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  VIEWER
  SUPER_ADMIN
  TENANT_OWNER
  TENANT_MANAGER
  TENANT_VIEWER
}

enum PlanType {
  FREE
  BASIC
  STANDARD
  PREMIUM
}

enum TenantStatus {
  ACTIVE
  SUSPENDED   // subscription unpaid — service disabled
  CANCELLED   // permanently cancelled
  TRIAL       // on free trial period
}

enum PartyType {
  DEALER
  SUPPLIER
}

enum AssignmentStatus {
  ISSUED
  IN_PROGRESS
  PARTIALLY_RETURNED
  COMPLETED
  CLOSED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PACKED
  DISPATCHED
  CANCELLED
}

enum PaymentMode {
  CASH
  BANK_TRANSFER
  UPI
}

enum PaymentType {
  DEALER_PAYMENT
  SUPPLIER_PAYMENT
  WORKER_PAYMENT
  DEALER_ADVANCE
  WORKER_ADVANCE
}

enum RawMaterialUnit {
  KG
  GRAM
  PIECE
  METER
  DOZEN
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM LEVEL — managed by Flowoid (SUPER_ADMIN)
// These tables exist above all tenants.
// ─────────────────────────────────────────────────────────────────────────────

// Represents each client business on the platform
model Tenant {
  id               String       @id @default(uuid())
  name             String                          // "Ayanshi Imitation"
  slug             String       @unique            // "ayanshi-imitation" — used in URLs
  email            String?                         // primary contact email
  phone            String?                         // primary contact phone
  address          String?

  // Subscription
  plan             PlanType     @default(FREE)
  status           TenantStatus @default(TRIAL)
  trialEndsAt      DateTime?
  subscriptionEndsAt DateTime?

  // Branding (for future white-label)
  logoUrl          String?
  businessCategory String?      // "Imitation Jewellery", future tenants may differ

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations — every business-level table links here
  users                    TenantUser[]
  designs                  Design[]
  designCategories         DesignCategory[]
  workers                  Worker[]
  assignments              WorkerAssignment[]
  goodsReturns             GoodsReturn[]
  workerPayments           WorkerPayment[]
  rawMaterialTypes         RawMaterialType[]
  rawMaterialPurchases     RawMaterialPurchase[]
  rawMaterialIssuances     RawMaterialIssuance[]
  supplementaryTypes       SupplementaryMaterialType[]
  supplementaryIssuances   SupplementaryIssuance[]
  inventoryStocks          InventoryStock[]
  packagingBatches         PackagingBatch[]
  parties                  Party[]
  dealerDesignPrices       DealerDesignPrice[]
  orders                   Order[]
  orderItems               OrderItem[]
  payments                 Payment[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS
// User = identity only (who you are)
// TenantUser = what role you have inside a specific tenant
// A SUPER_ADMIN has a User record but NO TenantUser record.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?
  phone        String   @unique
  passwordHash String
  role         Role     @default(TENANT_MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // A SUPER_ADMIN will have no tenantMemberships.
  // A TENANT_OWNER/MANAGER/VIEWER will have exactly one (for now).
  // Future: one user could be manager in multiple tenants (multi-tenant staff).
  tenantMemberships TenantUser[]
  refreshTokens     AuthRefreshToken[]
  rawMaterialPurchases RawMaterialPurchase[]
  designs             Design[]
  workerAssignmentsCreated WorkerAssignment[]
  packagingBatchesPacked   PackagingBatch[]
  ordersCreated       Order[]
  paymentsRecorded    Payment[]

  @@map("users")
}

// Junction table — links a User to a Tenant with a specific role
// This is what gives a user access to a tenant's data
model TenantUser {
  id        String   @id @default(uuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      Role     // TENANT_OWNER, TENANT_MANAGER, or TENANT_VIEWER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId]) // a user can only have one role per tenant
  @@map("tenant_users")
}

model AuthRefreshToken {
  id                String    @id
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  tokenHash         String    @unique
  sessionId         String
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  revokedAt         DateTime?
  revokedReason     String?
  replacedByTokenId String?

  @@index([userId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("auth_refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// ALL TABLES BELOW ARE TENANT-SCOPED
// Every table has tenantId — data is always filtered by tenant in queries.
// A user can NEVER see data from another tenant.
// ─────────────────────────────────────────────────────────────────────────────

model RawMaterialType {
  id          String          @id @default(uuid())
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  name        String
  unit        RawMaterialUnit @default(KG)
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  purchases   RawMaterialPurchase[]
  assignments WorkerAssignment[]
  issuances   RawMaterialIssuance[]

  @@unique([tenantId, name]) // name unique WITHIN a tenant, not globally
  @@map("raw_material_types")
}

model RawMaterialPurchase {
  id             String          @id @default(uuid())
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  materialType   RawMaterialType @relation(fields: [materialTypeId], references: [id])
  materialTypeId String
  supplier       Party           @relation(fields: [supplierId], references: [id])
  supplierId     String
  quantity       Float
  costPerUnit    Decimal         @db.Decimal(10, 2)
  totalCost      Decimal         @db.Decimal(10, 2)
  purchaseDate   DateTime        @default(now())
  invoiceNumber  String?
  notes          String?
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime        @default(now())

  @@map("raw_material_purchases")
}

model SupplementaryMaterialType {
  id            String   @id @default(uuid())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String
  name          String
  unit          String
  description   String?
  isActive      Boolean  @default(true)
  stockQuantity Float    @default(0)
  createdAt     DateTime @default(now())

  issuances SupplementaryIssuance[]

  @@unique([tenantId, name])
  @@map("supplementary_material_types")
}

model SupplementaryIssuance {
  id           String                    @id @default(uuid())
  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String
  assignment   WorkerAssignment          @relation(fields: [assignmentId], references: [id])
  assignmentId String
  material     SupplementaryMaterialType @relation(fields: [materialId], references: [id])
  materialId   String
  quantity     Float
  issuedAt     DateTime                  @default(now())
  notes        String?

  @@map("supplementary_issuances")
}

model DesignCategory {
  id       String   @id @default(uuid())
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  name     String
  createdAt DateTime @default(now())

  designs Design[]

  @@unique([tenantId, name])
  @@map("design_categories")
}

model Design {
  id                String         @id @default(uuid())
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId          String
  designCode        String
  name              String
  category          DesignCategory @relation(fields: [categoryId], references: [id])
  categoryId        String
  material          String?
  finish            String?
  diamondCount      Int            @default(0)
  pieceRateRs       Decimal        @db.Decimal(8, 2)
  salePricePerDozen Decimal        @db.Decimal(10, 2)
  imageUrl          String?
  isActive          Boolean        @default(true)
  notes             String?
  createdBy         User           @relation(fields: [createdById], references: [id])
  createdById       String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  assignments   WorkerAssignment[]
  inventoryStock InventoryStock?
  orderItems    OrderItem[]
  dealerPricing DealerDesignPrice[]

  @@unique([tenantId, designCode]) // design code unique within tenant
  @@map("designs")
}

model DealerDesignPrice {
  id            String  @id @default(uuid())
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String
  dealer        Party   @relation(fields: [dealerId], references: [id])
  dealerId      String
  design        Design  @relation(fields: [designId], references: [id])
  designId      String
  pricePerDozen Decimal @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  @@unique([tenantId, dealerId, designId])
  @@map("dealer_design_prices")
}

model Party {
  id             String    @id @default(uuid())
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  partyType      PartyType
  name           String
  phone          String?
  email          String?
  address        String?
  city           String?
  gstNumber      String?
  creditLimit    Decimal   @default(0) @db.Decimal(12, 2)
  creditDays     Int       @default(0)
  openingBalance Decimal   @default(0) @db.Decimal(12, 2)
  isActive       Boolean   @default(true)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  rawMaterialPurchases RawMaterialPurchase[]
  orders               Order[]
  payments             Payment[]
  dealerPricing        DealerDesignPrice[]

  @@map("parties")
}

model Worker {
  id            String   @id @default(uuid())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String
  name          String
  phone         String?
  address       String?
  idProofType   String?
  idProofNumber String?
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignments    WorkerAssignment[]
  workerPayments WorkerPayment[]

  @@map("workers")
}

model WorkerAssignment {
  id                    String           @id @default(uuid())
  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId              String
  worker                Worker           @relation(fields: [workerId], references: [id])
  workerId              String
  design                Design           @relation(fields: [designId], references: [id])
  designId              String
  rawMaterialType       RawMaterialType  @relation(fields: [rawMaterialTypeId], references: [id])
  rawMaterialTypeId     String
  rawMaterialQty        Float
  expectedPieces        Int
  returnedPieces        Int              @default(0)
  rejectedPieces        Int              @default(0)
  pieceRateAtAssignment Decimal          @db.Decimal(8, 2)
  status                AssignmentStatus @default(ISSUED)
  issuedAt              DateTime         @default(now())
  expectedReturnDate    DateTime?
  completedAt           DateTime?
  notes                 String?
  createdBy             User             @relation(fields: [createdById], references: [id])
  createdById           String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  goodsReturns           GoodsReturn[]
  rawMaterialIssuance    RawMaterialIssuance?
  supplementaryIssuances SupplementaryIssuance[]

  @@map("worker_assignments")
}

model GoodsReturn {
  id             String           @id @default(uuid())
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  assignment     WorkerAssignment @relation(fields: [assignmentId], references: [id])
  assignmentId   String
  piecesReturned Int
  rejectedPieces Int              @default(0)
  acceptedPieces Int
  earningAmount  Decimal          @db.Decimal(10, 2)
  returnedAt     DateTime         @default(now())
  notes          String?

  @@map("goods_returns")
}

model WorkerPayment {
  id          String      @id @default(uuid())
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  worker      Worker      @relation(fields: [workerId], references: [id])
  workerId    String
  amount      Decimal     @db.Decimal(10, 2)
  paymentMode PaymentMode @default(CASH)
  isAdvance   Boolean     @default(false)
  paidAt      DateTime    @default(now())
  notes       String?

  @@map("worker_payments")
}

model InventoryStock {
  id               String   @id @default(uuid())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId         String
  design           Design   @relation(fields: [designId], references: [id])
  designId         String   @unique
  unpackagedPieces Int      @default(0)
  packagedDozens   Int      @default(0)
  lowStockAlertAt  Int      @default(5)
  updatedAt        DateTime @updatedAt

  packagingBatches PackagingBatch[]

  @@map("inventory_stock")
}

model PackagingBatch {
  id             String         @id @default(uuid())
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  inventoryStock InventoryStock @relation(fields: [stockId], references: [id])
  stockId        String
  dozensPackaged Int
  piecesUsed     Int
  packedAt       DateTime       @default(now())
  packedBy       User           @relation(fields: [packedById], references: [id])
  packedById     String
  notes          String?

  @@map("packaging_batches")
}

model Order {
  id             String      @id @default(uuid())
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  orderNumber    String
  dealer         Party       @relation(fields: [dealerId], references: [id])
  dealerId       String
  status         OrderStatus @default(DRAFT)
  subtotalAmount Decimal     @db.Decimal(12, 2) @default(0)
  discountAmount Decimal     @db.Decimal(12, 2) @default(0)
  totalAmount    Decimal     @db.Decimal(12, 2) @default(0)
  isCreditOrder  Boolean     @default(false)
  dueDate        DateTime?
  dispatchedAt   DateTime?
  transportMode  String?
  trackingRef    String?
  cancelledAt    DateTime?
  cancelReason   String?
  notes          String?
  createdBy      User        @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items    OrderItem[]
  payments Payment[]

  @@unique([tenantId, orderNumber]) // order number unique within tenant
  @@map("orders")
}

model OrderItem {
  id               String  @id @default(uuid())
  tenant           Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId         String
  order            Order   @relation(fields: [orderId], references: [id])
  orderId          String
  design           Design  @relation(fields: [designId], references: [id])
  designId         String
  quantityDozens   Int
  pricePerDozen    Decimal @db.Decimal(10, 2)
  lineTotal        Decimal @db.Decimal(12, 2)
  dispatchedDozens Int     @default(0)

  @@map("order_items")
}

model Payment {
  id           String      @id @default(uuid())
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId     String
  paymentType  PaymentType
  paymentMode  PaymentMode
  party        Party?      @relation(fields: [partyId], references: [id])
  partyId      String?
  order        Order?      @relation(fields: [orderId], references: [id])
  orderId      String?
  amount       Decimal     @db.Decimal(12, 2)
  isAdvance    Boolean     @default(false)
  notes        String?
  recordedBy   User        @relation(fields: [recordedById], references: [id])
  recordedById String
  paidAt       DateTime    @default(now())
  createdAt    DateTime    @default(now())

  @@map("payments")
}

model RawMaterialIssuance {
  id             String           @id @default(uuid())
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  materialType   RawMaterialType  @relation(fields: [materialTypeId], references: [id])
  materialTypeId String
  assignment     WorkerAssignment @relation(fields: [assignmentId], references: [id])
  assignmentId   String           @unique
  quantity       Float
  issuedAt       DateTime         @default(now())
  notes          String?

  @@map("raw_material_issuances")
}
//   @@map("raw_material_issuances")
// }


